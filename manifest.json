{
    "manifest_version": 3,
    "name": "Tab Sandwich",
    "version": "2.0.0",
    "description": "Save, organize, and revisit browser tabs — with categories, quick filters, and outdated-tab tracking.",
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "images/icon-16.png",
            "32": "images/icon-32.png",
            "48": "images/icon-48.png",
            "128": "images/icon-128.png"
        }
    },
    "permissions": [
        "activeTab",
        "storage"
    ],
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Alt+S",
                "mac": "Alt+S"
            },
            "description": "Open Tab Sandwich"
        }
    }
}